<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    SECURITY TEST SUITE
    Runs only security-tagged tests (auth, 401, 403 scenarios).

    Command: mvn test -Dsuite=security
-->
<suite name="API Automation Suite - Security"
       verbose="2"
       parallel="methods"
       thread-count="2">

    <parameter name="env"     value="qa"/>
    <parameter name="retries" value="0"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.api.listeners.RetryListener"/>
    </listeners>

    <test name="User API - Security Tests">
        <groups>
            <run>
                <include name="security"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.tests.users.UserApiTest"/>
        </classes>
    </test>

</suite>
