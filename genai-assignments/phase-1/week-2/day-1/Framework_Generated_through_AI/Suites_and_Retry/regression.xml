<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    REGRESSION TEST SUITE
    Runs all regression tests in parallel for faster execution.
    Includes: smoke + regression + security groups.

    Command: mvn test -Dsuite=regression
             mvn test -Pstagng -Dsuite=regression
-->
<suite name="API Automation Suite - Regression"
       verbose="2"
       parallel="methods"
       thread-count="5"
       data-provider-thread-count="5">

    <parameter name="env"     value="qa"/>
    <parameter name="retries" value="1"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.api.listeners.RetryListener"/>
    </listeners>

    <!-- User API Regression -->
    <test name="User API - Regression Tests" preserve-order="false">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <include name="security"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.tests.users.UserApiTest"/>
        </classes>
    </test>

</suite>
