<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    SMOKE TEST SUITE
    Runs only the most critical tests to verify core API health.
    Fast feedback — expected to complete in under 2 minutes.

    Command: mvn test -Dsuite=smoke
             mvn test -Dsuite=smoke -Denv=staging
-->
<suite name="API Automation Suite - Smoke"
       verbose="1"
       parallel="methods"
       thread-count="2"
       data-provider-thread-count="2">

    <parameter name="env"     value="qa"/>
    <parameter name="retries" value="0"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.api.listeners.RetryListener"/>
    </listeners>

    <test name="User API - Smoke Tests" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.tests.users.UserApiTest"/>
        </classes>
    </test>

</suite>
